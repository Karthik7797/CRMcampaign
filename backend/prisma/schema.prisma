generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(COUNSELLOR)
  avatar       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leads        Lead[]   @relation("AssignedLeads")
  tasks        Task[]
  activities   Activity[]
  leadNotes    LeadNote[]
  influencerLeads        InfluencerLead[]   @relation("InfluencerAssignedLeads")
  influencerTasks        InfluencerLeadTask[]
  influencerActivities InfluencerLeadActivity[]
  influencerLeadNotes  InfluencerLeadNote[]
}

enum Role {
  ADMIN
  MANAGER
  COUNSELLOR
  MARKETING
  INFLUENCER
}

model Lead {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String
  course        String?
  source        LeadSource   @default(WEBSITE)
  landingPage   String?
  status        LeadStatus   @default(NEW)
  priority      Priority     @default(MEDIUM)
  notes         String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  city          String?
  qualification String?
  assignedTo    User?        @relation("AssignedLeads", fields: [assignedToId], references: [id])
  assignedToId  String?
  pipelineStage PipelineStage @default(ENQUIRY)
  activities    Activity[]
  tasks         Task[]
  communications Communication[]
  leadNotes     LeadNote[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model LeadNote {
  id        String   @id @default(cuid())
  content   String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

enum LeadSource {
  WEBSITE
  LANDING_PAGE_MBA
  LANDING_PAGE_ENGINEERING
  LANDING_PAGE_EDUCATION
  LANDING_PAGE_SCHOLARSHIP
  LANDING_PAGE_ONLINE
  FACEBOOK
  GOOGLE
  INSTAGRAM
  REFERRAL
  WALK_IN
  PHONE
  EMAIL
  SELF_LOCAL
  GOOGLE_FORM
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  LOST
  JUNK
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum PipelineStage {
  ENQUIRY
  CONTACTED
  DEMO
  UNIVERSITY_SELECTION
  OFFER_LETTER
  VISA
  ACCOMMODATION
  PART_TIME_JOB
  FULL_TIME
  SHORTLISTED
  APPLICATION_SENT
  APPLICATION_RECEIVED
  ENROLLED
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  content   String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean    @default(false)
  priority    Priority   @default(MEDIUM)
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  assignedTo  User       @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Communication {
  id        String   @id @default(cuid())
  type      CommType
  subject   String?
  content   String
  status    String   @default("SENT")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  createdAt DateTime @default(now())
}

enum CommType {
  EMAIL
  SMS
  WHATSAPP
  CALL
  NOTE
}

// ── Influencer Leads (Google Form submissions) ─────────────────────

model InfluencerLead {
  id                String       @id @default(cuid())
  studentName       String
  studentEmail      String
  studentMobile     String
  collegeName       String?
  parentName        String?
  parentMobile      String?
  parentOccupation  String?
  intake            String?
  interestedCountry String?
  mode              String?      // e.g. "Office Visit", "Online"
  remarks           String?
  source            LeadSource   @default(GOOGLE_FORM)
  status            LeadStatus   @default(NEW)
  priority          Priority     @default(MEDIUM)
  pipelineStage     PipelineStage @default(ENQUIRY)
  assignedTo        User?        @relation("InfluencerAssignedLeads", fields: [assignedToId], references: [id])
  assignedToId      String?
  activities        InfluencerLeadActivity[]
  tasks             InfluencerLeadTask[]
  communications    InfluencerLeadCommunication[]
  leadNotes         InfluencerLeadNote[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model InfluencerLeadActivity {
  id        String   @id @default(cuid())
  type      String
  content   String
  lead      InfluencerLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model InfluencerLeadTask {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean    @default(false)
  priority    Priority   @default(MEDIUM)
  lead        InfluencerLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId      String?
  assignedTo  User       @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model InfluencerLeadCommunication {
  id        String   @id @default(cuid())
  type      CommType
  subject   String?
  content   String
  status    String   @default("SENT")
  lead      InfluencerLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  createdAt DateTime @default(now())
}

model InfluencerLeadNote {
  id        String   @id @default(cuid())
  content   String
  lead      InfluencerLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}
