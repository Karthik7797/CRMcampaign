# Database Configuration
# Get this from your PostgreSQL provider (Render, Neon, Supabase, etc.)

# For Supabase with Connection Pooler (Recommended for Render):
# 1. Go to Supabase Dashboard → Project Settings → Database → Connection Pooling
# 2. Copy the "Transaction mode" connection URI
# 3. Make sure it ends with: ?pgbouncer=true&connection_limit=20&pool_timeout=30&recycle=300
# Example:
# DATABASE_URL="postgresql://postgres.xxx:password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20&pool_timeout=30&recycle=300"

# For Supabase Direct Connection (Alternative):
# Use port 5432 instead of 6543, and remove .pooler from the hostname
# DATABASE_URL="postgresql://postgres.xxx:password@aws-1-ap-southeast-2.supabase.co:5432/postgres?sslmode=require"

# For other providers (Neon, Railway, etc.):
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# JWT Secret - Change this to a random secure string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend URL for CORS
# Add your Vercel production URL here
FRONTEND_URL="https://cr-mcampaign-3irx.vercel.app"

# Email Configuration (Optional - for future email features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
